{
  "version": 2,
  "builds": [
    { "src": "api/claude.py", "use": "@vercel/python" },
    { "src": "dashboard.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/claude", "dest": "/api/claude.py" },
    { "src": "/", "dest": "/dashboard.html" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}